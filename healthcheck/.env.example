# ==========================================
# HEALTHCHECK DATABASE CONFIG (Supabase)
# ==========================================
# Needed to load/save state so you only get 1 notification when a service drops.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your_supabase_secret_key

# ==========================================
# MONITORED SERVICE CONFIGURATION
# ==========================================
# Public URL of your backend health endpoint to monitor (optional)
HEALTHCHECK_BACKEND_URL=https://your-cookbook-backend.com/health
# Public URL of your frontend website to monitor (optional)
HEALTHCHECK_WEBSITE_URL=https://your-cookbook-website.com

# ==========================================
# CREDENTIALS TO TEST API INTEGRATIONS (Optional)
# ==========================================
# If configured, checks that the APIs respond correctly to your keys.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
RAPIDAPI_KEY=
RAPIDAPI_SOCIAL_HOST=social-download-all-in-one.p.rapidapi.com
APIFY_TOKEN=

# ==========================================
# MOBILE NOTIFICATION CHANNELS
# ==========================================
# ntfy.sh topic name for phone push notifications (optional)
NTFY_TOPIC=your-unique-cookbook-alerts-topic
# Telegram configuration for notification delivery (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
