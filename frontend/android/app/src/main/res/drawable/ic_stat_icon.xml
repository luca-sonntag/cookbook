<?xml version="1.0" encoding="utf-8"?>
<!--
  Status-bar (small) icon for cooking-timer local notifications.
  Android forces the small icon to a flat white-on-transparent silhouette and
  tints it, so this is a monochrome rendition of the CookBuddy brand mark:
  a fork and spoon joined in a bowl shape framing a play triangle.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="#FFFFFF">
    <!-- Fork tines + fork/spoon joined stems (the "U" bowl) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M5.3,3 L5.3,6.6 M6.6,2.8 L6.6,6.6 M7.9,3 L7.9,6.6 M6.6,6.6 C6.6,10 5,12.5 6.2,15.8 C7.6,19.5 16.4,19.5 17.8,15.8 C19,12.5 17.4,10 17.4,6.6" />
    <!-- Spoon bowl -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M17.4,2.3 C16.3,2.3 15.6,3.4 15.6,4.8 C15.6,6.2 16.3,7 17.4,7 C18.5,7 19.2,6.2 19.2,4.8 C19.2,3.4 18.5,2.3 17.4,2.3 Z" />
    <!-- Play triangle -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M10.2,9.2 L10.2,14.8 L15,12 Z" />
</vector>
