{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npm run build && cap sync android",
    "cap:open": "cap open android",
    "cap:run": "npm run build && cap sync android && cap run android",
    "cap:live": "cap run android --live-reload --host localhost --port 5173 --forwardPorts 5173:5173",
    "release": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1",
    "release:patch": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1 -Bump patch",
    "release:minor": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1 -Bump minor",
    "release:major": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1 -Bump major",
    "deploy:internal": "powershell -ExecutionPolicy Bypass -File scripts/deploy-playstore.ps1 -Track internal",
    "deploy:internal:patch": "powershell -ExecutionPolicy Bypass -File scripts/deploy-playstore.ps1 -Track internal -Bump patch",
    "deploy:internal:upload": "powershell -ExecutionPolicy Bypass -File scripts/deploy-playstore.ps1 -Track internal -SkipBuild",
    "deploy:playstore": "powershell -ExecutionPolicy Bypass -File scripts/deploy-playstore.ps1",
    "deploy:production": "powershell -ExecutionPolicy Bypass -File scripts/deploy-playstore.ps1 -Track production",
    "deploy:production:patch": "powershell -ExecutionPolicy Bypass -File scripts/deploy-playstore.ps1 -Track production -Bump patch",
    "deploy:production:upload": "powershell -ExecutionPolicy Bypass -File scripts/deploy-playstore.ps1 -Track production -SkipBuild"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-social-login": "^8.3.33",
    "@gravity-ui/icons": "^2.18.0",
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@revenuecat/purchases-capacitor": "^13.2.1",
    "@supabase/supabase-js": "^2.108.2",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "send-intent": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
