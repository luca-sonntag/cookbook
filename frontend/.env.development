# =====================================================================
# DEV / PREVIEW MODE  (Vite `--mode development`)
# =====================================================================
# Used by `npm run build:dev` and `npm run dev` for the shared Railway dev
# environment (dev backend + dev Supabase). The web build is opened in the
# phone browser to test a feature branch before merging.
#
# The real URLs/keys are injected as Railway *build variables* for the preview
# service. For a LOCAL dev run, copy the needed values into
# `.env.development.local` (git-ignored) — do NOT put secrets in this committed
# file.

# Point the frontend at the hosted dev backend (full origin, no trailing slash).
# Leave empty locally to use the Vite proxy to localhost:3000 instead.
VITE_API_BASE_URL=

# Managed Supabase dev project (snagbite-dev). URL + anon key are public by design.
VITE_SUPABASE_URL=https://nmphuwywxirervquvgoa.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5tcGh1d3l3eGlyZXJ2cXV2Z29hIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQ4MzYyNjcsImV4cCI6MjEwMDQxMjI2N30.jejPI58f_PMq6St8pqn3yRZSaeB5S7MQ3gbw2nwsqzg

# Auto-login as the seeded test user (bypasses the login screen).
# NEVER set this in the production / Play Store build.
VITE_TEST_USER_EMAIL=test@dev.snagbite.local
# Password is a credential — keep it in frontend/.env.development.local (git-ignored):
#   VITE_TEST_USER_PASSWORD=…

# Website origin for external admin links
VITE_WEBSITE_URL=http://localhost:5174

