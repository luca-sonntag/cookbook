# ==========================================
# API & SERVER CONNECTIONS
# ==========================================
# Backend API origin. Leave EMPTY for local dev (uses Vite proxy).
# The production URL is automatically read from .env.production during releases!
VITE_API_BASE_URL=

# ==========================================
# DATABASE & AUTH (Supabase)
# ==========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# ==========================================
# SOCIAL LOGIN (Google)
# ==========================================
# Google OAuth *Web* client ID (from Google Cloud Console). Used by the native
# Google Sign-In flow on Android as the token audience / serverClientId. Must be
# the same Web client ID configured as the Google provider in Supabase Auth.
VITE_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id

# ==========================================
# MONETIZATION (RevenueCat)
# ==========================================
VITE_REVENUECAT_ANDROID_API_KEY=your_test_revenuecat_api_key
