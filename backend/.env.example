# Server config
PORT=3000

# API Credentials
# Social scraping runs an ordered provider registry (src/scrapers/providers/):
#   1. rapidapi-all-in-one  2. local-ytdlp  3. apify-actor (optional).
#
# Primary provider: "Social Download All In One" on RapidAPI — direct CDN video URLs +
# caption for IG/TikTok/YouTube/Facebook (src/scrapers/providers/rapidApi.ts).
RAPIDAPI_KEY=your_rapidapi_key
# Apify token for the optional first-party actor fallback (src/scrapers/providers/apifyActor.ts).
APIFY_TOKEN=your_apify_api_token
# Actor id of your deployed social downloader (maintained in the separate apify-actor repo),
# set after `apify push`. The apify-actor provider is disabled unless this is set.
APIFY_SOCIAL_ACTOR_ID=your_apify_username/social-video-downloader
GEMINI_API_KEY=your_gemini_api_key

# Database config
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key

# Gemini Config (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TEMPERATURE=0

# Response Language Config
RECIPE_LANGUAGE=German

# Preferred Units Config
# Options for PREFERRED_TEMPERATURE_UNIT: Celsius, Fahrenheit, or "both" (e.g. 200°C (400°F))
PREFERRED_TEMPERATURE_UNIT=Celsius
# Options for PREFERRED_UNIT_SYSTEM: metric (grams, ml, kg), imperial (oz, cups, lbs, fl oz)
PREFERRED_UNIT_SYSTEM=metric

# Optional yt-dlp cookie configuration to bypass bot checks (e.g. for YouTube)
# Set to 'chrome', 'firefox', etc. to scrape cookies from local browser (dev only)
# YTDLP_COOKIES_FROM_BROWSER=chrome
# Or set to path of a Netscape cookie file (defaults to cookies.txt if file exists)
# YTDLP_COOKIES_FILE=cookies.txt

# Rate Limiting Config
# Timeframe window in days for rolling rate limits
EXTRACTION_LIMIT_WINDOW_DAYS=1
# Default number of extractions allowed in the window for Free tier users
FREE_MAX_EXTRACTIONS_PER_WINDOW=3
# Default number of extractions allowed in the window for Premium tier users
PREMIUM_MAX_EXTRACTIONS_PER_WINDOW=50
# Max number of saved recipes (cookbook entries) a Free account may keep. Premium is unlimited.
FREE_MAX_SAVED_RECIPES=5

# Beta configuration
BETA_ACTIVE=false
BETA_MAX_EXTRACTIONS_PER_WINDOW=10
BETA_MAX_SAVED_RECIPES=20

REVENUECAT_SECRET_KEY=sk_example




