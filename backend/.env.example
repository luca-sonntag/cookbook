# ==========================================
# CORE SERVER CONFIGURATION
# ==========================================
PORT=3000

# ==========================================
# DATABASE & AUTH (Supabase)
# ==========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key

# ==========================================
# AI & NLP (Gemini)
# ==========================================
GEMINI_API_KEY=your_gemini_api_key
# Gemini Config (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TEMPERATURE=0

# ==========================================
# SCRAPING & PROVIDERS (Apify / RapidAPI)
# ==========================================
# Social scraping runs an ordered provider registry (src/scrapers/providers/):
#   1. rapidapi-all-in-one  2. local-ytdlp  3. apify-actor (optional).
# Primary provider: "Social Download All In One" on RapidAPI
RAPIDAPI_KEY=your_rapidapi_key
# Apify token for the optional first-party actor fallback
APIFY_TOKEN=your_apify_api_token
# Actor id of the deployed social downloader (apify-actor repo)
APIFY_SOCIAL_ACTOR_ID=your_apify_username/social-video-downloader

# Optional yt-dlp cookie configuration to bypass bot checks (e.g. for YouTube)
# Set to 'chrome', 'firefox', etc. to scrape cookies from local browser (dev only)
# YTDLP_COOKIES_FROM_BROWSER=chrome
# Or set to path of a Netscape cookie file (defaults to cookies.txt if file exists)
# YTDLP_COOKIES_FILE=cookies.txt

# ==========================================
# MONETIZATION (RevenueCat)
# ==========================================
REVENUECAT_SECRET_KEY=sk_example

# ==========================================
# RECIPE & LOCALIZATION CONFIG
# ==========================================
RECIPE_LANGUAGE=German
# Options: Celsius, Fahrenheit, or "both"
PREFERRED_TEMPERATURE_UNIT=Celsius
# Options: metric (grams, ml, kg), imperial (oz, cups, lbs, fl oz)
PREFERRED_UNIT_SYSTEM=metric

# ==========================================
# USAGE LIMITS & TIERS
# ==========================================
# Timeframe window in days for rolling rate limits
EXTRACTION_LIMIT_WINDOW_DAYS=1
# Default number of extractions allowed in the window for Free tier users
FREE_MAX_EXTRACTIONS_PER_WINDOW=3
# Max number of saved recipes (cookbook entries) a Free account may keep
FREE_MAX_SAVED_RECIPES=5
# Default number of extractions allowed in the window for Premium tier users
PREMIUM_MAX_EXTRACTIONS_PER_WINDOW=50

# ==========================================
# BETA CONFIGURATION
# ==========================================
BETA_ACTIVE=false
BETA_MAX_EXTRACTIONS_PER_WINDOW=10
BETA_MAX_SAVED_RECIPES=20

# ==========================================
# ADMIN CONFIGURATION
# ==========================================
# Admin settings (comma-separated emails allowed to log in as admin)
ADMIN_EMAILS=

# ==========================================
# HEALTHCHECK CONFIGURATION
# ==========================================
# URL of your frontend website to monitor (optional)
HEALTHCHECK_WEBSITE_URL=https://your-cookbook-website.com
# URL of your backend health endpoint to monitor (optional, used by standalone CLI check)
HEALTHCHECK_BACKEND_URL=https://your-cookbook-backend.com/health
# ntfy.sh topic name for phone push notifications (optional)
# Download the free ntfy mobile app and subscribe to this topic
NTFY_TOPIC=your-unique-cookbook-alerts-topic
# Telegram configuration for notification delivery (optional)
# Get a token from @BotFather and your chat id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
