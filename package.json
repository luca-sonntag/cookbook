{
  "name": "instagram-reel-recipe-extractor-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev": "concurrently -n \"backend,frontend\" -c \"blue,green\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "npm run build -w backend",
    "build:frontend": "npm run build -w frontend",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "npm run start -w backend",
    "preview": "npm run preview -w backend",
    "test-client": "npm run test-client -w backend",
    "test-grid": "npm run test-grid -w backend",
    "tunnel": "npm run tunnel -w backend",
    "tunnel:server": "npm run tunnel:server -w backend",
    "kill-server": "powershell -Command \"$conn = Get-NetTCPConnection -LocalPort 3000 -State Listen -ErrorAction SilentlyContinue; if ($conn) { Stop-Process -Id $conn.OwningProcess -Force }; exit 0\"",
    "kill-tunnel": "powershell -Command \"Stop-Process -Name ngrok -ErrorAction SilentlyContinue; exit 0\""
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0"
  }
}
