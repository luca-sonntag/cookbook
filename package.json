{
  "name": "instagram-reel-recipe-extractor",
  "version": "1.0.0",
  "description": "An Express.js API to extract recipes from Instagram Reels using Apify and Google Gemini",
  "main": "dist/src/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --inspect src/index.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently -n \"backend,frontend\" -c \"blue,green\" \"npm run dev\" \"npm run dev:frontend\"",
    "build": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build:frontend && npm run build",
    "start": "cross-env NODE_ENV=production node dist/src/index.js",
    "preview": "node dist/src/index.js",
    "test-client": "tsx test-client.ts",
    "tunnel": "ngrok start recipe-api",
    "tunnel:server": "node ngrok-quickstart/server.cjs",
    "kill-server": "powershell -Command '$conn = Get-NetTCPConnection -LocalPort 3000 -State Listen -ErrorAction SilentlyContinue; if ($conn) { Stop-Process -Id $conn.OwningProcess -Force }; exit 0'",
    "kill-tunnel": "powershell -Command \"Stop-Process -Name ngrok -ErrorAction SilentlyContinue; exit 0\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.11.0",
    "@supabase/supabase-js": "^2.108.2",
    "apify-client": "^2.9.4",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "youtube-dl-exec": "^3.1.8"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20.14.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "tsx": "^4.15.2",
    "typescript": "^5.4.5"
  }
}
